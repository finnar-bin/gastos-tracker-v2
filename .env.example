# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Drizzle / Postgres
DATABASE_URL="postgresql://postgres.[USER]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@gastos-mail.yourdomain.com"

# Recurring schedule cron schedule
CRON_SECRET=

# Web push (generate via: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
